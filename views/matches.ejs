<%- include('partials/header', { title: 'مباريات اليوم بث مباشر | ' + siteName, description: 'جدول مباريات اليوم بث مباشر بدون تقطيع، يلا شوت، يلا كورة.', url: '/matches.html' }) %>

<!-- World Cup 2026 Banner -->
<div class="wc-banner" style="background: linear-gradient(135deg, #4a1a6b 0%, #2d1b69 25%, #1a237e 50%, #0d47a1 75%, #00695c 100%); padding: 30px 20px; text-align: center; position: relative; overflow: hidden; border-bottom: 3px solid #ffd700;">
  <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(circle at 20% 50%, rgba(255,215,0,0.1) 0%, transparent 50%), radial-gradient(circle at 80% 50%, rgba(255,215,0,0.1) 0%, transparent 50%); pointer-events: none;"></div>
  <div style="position: relative; z-index: 1; max-width: 700px; margin: 0 auto;">
    <div style="display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 12px;">
      <img src="https://flagcdn.com/w40/us.png" alt="USA" style="width: 36px; height: auto; border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.3);">
      <img src="https://flagcdn.com/w40/ca.png" alt="Canada" style="width: 36px; height: auto; border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.3);">
      <img src="https://flagcdn.com/w40/mx.png" alt="Mexico" style="width: 36px; height: auto; border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.3);">
    </div>
    <h2 style="color: #ffd700; font-size: 1.6rem; font-weight: 800; margin: 0 0 4px 0; text-shadow: 0 2px 10px rgba(0,0,0,0.3); letter-spacing: 1px;">⚽ كأس العالم 2026 FIFA™</h2>
    <p style="color: rgba(255,255,255,0.9); font-size: 0.95rem; margin: 0; font-weight: 500;">تابع مباريات كأس العالم بث مباشر</p>
    <div style="display: flex; justify-content: center; gap: 6px; margin-top: 14px;">
      <span style="width: 30px; height: 3px; background: #e94560; border-radius: 2px; display: inline-block;"></span>
      <span style="width: 30px; height: 3px; background: #ffd700; border-radius: 2px; display: inline-block;"></span>
      <span style="width: 30px; height: 3px; background: #00bcd4; border-radius: 2px; display: inline-block;"></span>
    </div>
  </div>
</div>

<section class="category-section">
  <div class="section-header">
    <h1><i class="fas fa-futbol"></i> مباريات اليوم بث مباشر</h1>
    <p>تابع أهم مباريات اليوم بث مباشر بدون تقطيع، روابط محدثة باستمرار.</p>
  </div>
  
  <div class="matches-list">
    <% if (matches && matches.length > 0) { %>
      <% for (let i = 0; i < matches.length; i++) { const match = matches[i]; %>
        <div class="match-card <%= match.status.includes('جارية') || match.status.includes('الآن') ? 'live' : (match.status.includes('انتهت') ? 'ended' : 'soon') %>">
          <a href="match/<%= match.id %>.html" class="match-link" title="بث مباشر مباراة <%= match.team1 %> و <%= match.team2 %>">
            <div class="match-teams">
              <div class="team">
                <img src="<%= match.logo1 %>" alt="<%= match.team1 %>" loading="lazy" referrerpolicy="no-referrer">
                <span class="team-name"><%= match.team1 %></span>
              </div>
              <div class="match-info-center">
                <div class="match-time"><%= match.time %></div>
                <div class="match-status-badge"><%= match.status %></div>
                <div class="match-vs"><%= (match.status.includes('انتهت') || match.status.includes('جارية') || match.status.includes('الآن')) ? (match.score || 'VS') : 'VS' %></div>
              </div>
              <div class="team">
                <img src="<%= match.logo2 %>" alt="<%= match.team2 %>" loading="lazy" referrerpolicy="no-referrer">
                <span class="team-name"><%= match.team2 %></span>
              </div>
            </div>
            <div class="match-details">
              <span class="detail-item"><i class="fas fa-trophy"></i> <%= match.league %></span>
              <span class="detail-item"><i class="fas fa-tv"></i> <%= match.channel %></span>
              <span class="detail-item"><i class="fas fa-microphone"></i> <%= match.commentator %></span>
            </div>
          </a>
        </div>
      <% } %>
    <% } else { %>
      <div class="empty-state">
        <i class="fas fa-futbol fa-4x"></i>
        <h2>لا توجد مباريات متاحة اليوم</h2>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
