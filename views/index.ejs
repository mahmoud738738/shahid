<%- include('partials/header', { title: '' }) %>
<div class="container">
  <% if (latest && latest.length > 0) { %>
    <section class="latest-section">
      <div class="section-header">
        <h2><i class="fas fa-bolt"></i> أحدث الإضافات</h2>
        <a href="/movies.html" class="view-all">عرض الكل <i class="fas fa-arrow-left"></i></a>
      </div>
      <div class="latest-grid">
        <% latest.forEach(function(m) { %>
          <a href="/movie/<%= m.vid %>.html" class="latest-card" title="<%= m.title %>">
            <div class="latest-card-poster">
              <img src="<%= m.poster || '' %>" alt="<%= m.title %>" loading="lazy">
              <% if (m.quality) { %><span class="quality-badge-sm"><%= m.quality.split(' - ')[0] %></span><% } %>
              <span class="play-overlay"><i class="fas fa-play"></i></span>
            </div>
            <div class="latest-card-info">
              <h3><%= m.title %></h3>
              <span class="latest-meta">
                <% if (m.year) { %><span><%= m.year %></span><% } %>
                <% if (m.type === 'series') { %><span class="type-badge">مسلسل</span><% } %>
              </span>
            </div>
          </a>
        <% }) %>
      </div>
    </section>
  <% } %>

  <section class="movies-section">
    <div class="section-header">
      <h2><i class="fas fa-list"></i> جميع الأفلام والمسلسلات</h2>
      <% if (updatedAt) { %>
        <span class="update-info">آخر تحديث: <%= new Date(updatedAt).toLocaleDateString('ar-EG', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
      <% } %>
    </div>

    <div class="movie-grid">
      <% movies.forEach(function(m) { %>
        <a href="/movie/<%= m.vid %>.html" class="movie-card" title="<%= m.title %>">
          <div class="movie-card-poster">
            <% if (m.poster) { %>
              <img src="<%= m.poster %>" alt="<%= m.title %>" loading="lazy">
            <% } else { %>
              <div class="no-poster"><i class="fas fa-film"></i></div>
            <% } %>
            <% if (m.quality) { %>
              <span class="quality-badge"><%= m.quality.split(' - ')[0] %></span>
            <% } %>
            <% if (m.type === 'series') { %>
              <span class="type-badge-card">مسلسل</span>
            <% } %>
          </div>
          <div class="movie-card-info">
            <h3><%= m.title %></h3>
            <div class="movie-meta">
              <% if (m.year) { %><span><%= m.year %></span><% } %>
              <% if (m.quality) { %><span><%= m.quality.split(' - ')[0] %></span><% } %>
            </div>
          </div>
        </a>
      <% }) %>
    </div>

    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (page > 1) { %>
          <a href="/<%= pagePrefix %><%= page - 1 %>.html" class="page-link"><i class="fas fa-chevron-right"></i> السابق</a>
        <% } %>
        <span class="page-info">الصفحة <%= page %> من <%= totalPages %> (<%= total %>)</span>
        <% if (page < totalPages) { %>
          <a href="/<%= pagePrefix %><%= page + 1 %>.html" class="page-link">التالي <i class="fas fa-chevron-left"></i></a>
        <% } %>
      </div>
    <% } %>
  </section>
</div>
<%- include('partials/footer') %>
