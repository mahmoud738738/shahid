<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %><%= siteName %></title>
  
  <!-- SEO & Meta Tags -->
  <meta name="description" content="<%= typeof movie !== 'undefined' ? (movie.story ? movie.story.substring(0, 160) : 'مشاهدة وتحميل ' + movie.title) : 'مشاهدة وتحميل أحدث الأفلام والمسلسلات بجودة عالية' %>">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title + ' - ' : '' %><%= siteName %>">
  <meta property="og:description" content="<%= typeof movie !== 'undefined' ? (movie.story ? movie.story.substring(0, 160) : 'مشاهدة وتحميل ' + movie.title) : 'مشاهدة وتحميل أحدث الأفلام والمسلسلات بجودة عالية' %>">
  <% if (typeof movie !== 'undefined' && movie.poster) { %>
    <meta property="og:image" content="<%= movie.poster %>">
  <% } %>
  <meta property="og:type" content="<%= typeof movie !== 'undefined' ? 'video.movie' : 'website' %>">

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap" rel="stylesheet">
</head>
<body>
  <div class="app-layout">
    <aside class="sidebar">
      <div class="sidebar-header">
        <a href="/" class="logo">
          <div class="logo-dots">
            <span class="dot green"></span>
            <span class="dot cyan"></span>
            <span class="dot blue"></span>
          </div>
          <span class="logo-text">Shahid</span>
        </a>
      </div>
      <nav class="nav" id="mainNav">
        <a href="/" class="nav-link"><i class="fas fa-home"></i> الرئيسية</a>
        <a href="/movies.html" class="nav-link"><i class="fas fa-film"></i> الأفلام</a>
        <a href="/series.html" class="nav-link"><i class="fas fa-tv"></i> المسلسلات</a>
      </nav>
      <button class="menu-toggle" id="menuToggle" aria-label="القائمة"><i class="fas fa-bars"></i></button>
    </aside>
    <main class="main-content">
      <header class="mobile-header">
        <a href="/" class="logo">
          <div class="logo-dots">
            <span class="dot green"></span>
            <span class="dot cyan"></span>
            <span class="dot blue"></span>
          </div>
          Shahid
        </a>
        <button class="menu-toggle" onclick="document.querySelector('.sidebar').classList.toggle('active')">
          <i class="fas fa-bars"></i>
        </button>
      </header>
      <div class="main-inner">
